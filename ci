parameters:
  - name: version
    type: string
    displayName: "Version to release (e.g. 0.2.0)"

trigger:
  branches:
    include: [main]

pr:
  branches:
    include: [main]

pool:
  name: <self-hosted>

variables:
  - group: artifactory-creds
  - name: ansibleVersion
    value: "2.18.2"

stages:
  - stage: Lint
    jobs:
      - job: lint
        steps:
          - template: templates/setup-ansible.yml
          - script: ansible-lint --format=pep8
            displayName: ansible-lint

  - stage: Build
    dependsOn: Lint
    condition: |
      and(
        succeeded(),
        ne(variables['Build.Reason'], 'PullRequest')
      )
    jobs:
      - job: build
        steps:
          - template: templates/setup-ansible.yml
          - script: ansible-galaxy collection build --output-path $(Build.ArtifactStagingDirectory)
            displayName: Build collection
          - task: PublishBuildArtifacts@1
            inputs:
              pathToPublish: $(Build.ArtifactStagingDirectory)
              artifactName: collection
              publishLocation: Container

  - stage: Release
    dependsOn: Build
    condition: |
      and(
        succeeded(),
        eq(variables['Build.Reason'], 'Manual'),
        ne('${{ parameters.version }}', '')
      )
    jobs:
      - job: release
        steps:
          - checkout: self
            persistCredentials: true

          - template: templates/setup-ansible.yml

          - script: |
              set -e
              VERSION="${{ parameters.version }}"

              # Validate version format
              if ! [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
                echo "ERROR: version must be semver (e.g. 0.2.0), got: $VERSION"
                exit 1
              fi

              # Check the tag doesn't already exist
              if git rev-parse "$VERSION" >/dev/null 2>&1; then
                echo "ERROR: tag $VERSION already exists"
                exit 1
              fi

              # Bump galaxy.yml
              sed -i "s/^version:.*/version: $VERSION/" galaxy.yml

              # Configure git identity for the bot commit
              git config user.email "ci@mycompany.local"
              git config user.name "Release Bot"

              # Commit, tag, push
              git add galaxy.yml
              git commit -m "Release $VERSION"
              git tag "$VERSION"
              git push origin HEAD:main
              git push origin "$VERSION"
            displayName: Bump, commit, tag, push

          - script: |
              ansible-galaxy collection build --output-path $(Build.ArtifactStagingDirectory)
            displayName: Rebuild with new version

          - script: |
              cat > ansible.cfg <<'EOF'
              [galaxy]
              server_list = mycompany_artifactory

              [galaxy_server.mycompany_artifactory]
              url = $(ArtifactoryUrl)/artifactory/api/ansible/ansible-collections/
              token = ${ARTIFACTORY_TOKEN}
              EOF

              ansible-galaxy collection publish \
                $(Build.ArtifactStagingDirectory)/mycompany-*.tar.gz \
                --server mycompany_artifactory
            env:
              ARTIFACTORY_TOKEN: $(ArtifactoryToken)
            displayName: Publish to Artifactory
