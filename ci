trigger: none
pr: none

pool:
  name: <self-hosted>

parameters:
  - name: version
    type: string
    displayName: "Bundle version (e.g. 1.0.0)"

variables:
  - group: artifactory-creds
  - name: ansibleVersion
    value: "2.18.2"

stages:
  - stage: Bundle
    jobs:
      - job: bundle
        steps:
          - checkout: self
            persistCredentials: true
            clean: true

          - template: templates/setup-ansible.yml
            parameters:
              ansibleVersion: $(ansibleVersion)

          - script: |
              set -e
              VERSION="${{ parameters.version }}"
              [[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
                echo "ERROR: version must be semver, got: $VERSION"; exit 1; }
            displayName: Validate version

          - script: |
              set -e
              ansible-galaxy collection install \
                -r requirements.yml \
                -p ./collections \
                --force
            env:
              ARTIFACTORY_TOKEN: $(ArtifactoryToken)
            displayName: Install collections from Artifactory

          - script: |
              set -e
              echo "Installed collections:"
              ansible-galaxy collection list -p ./collections
              # Fail if expected collections didn't land
              for c in \
                ansible_collections/mycompany/hypervisor_common \
                ansible_collections/mycompany/hypervisor_controller \
                ansible_collections/mycompany/hypervisor_compute; do
                test -f "collections/$c/MANIFEST.json" || {
                  echo "ERROR: missing $c"; exit 1; }
              done
            displayName: Verify collection install

          - script: |
              set -e
              ansible-playbook playbooks/site.yml --syntax-check
            displayName: Syntax check playbooks

          - script: |
              set -e
              VERSION="${{ parameters.version }}"
              BUNDLE="acme-hq-c1-${VERSION}.tar.gz"

              # Write a manifest describing what's in the bundle
              cat > BUNDLE_MANIFEST.yml <<EOF
              deployment: acme-hq-c1
              version: $VERSION
              built: $(date -u +%Y-%m-%dT%H:%M:%SZ)
              built_by: $(Build.RequestedFor)
              pipeline_run: $(Build.BuildNumber)
              ansible_core: $(ansibleVersion)
              git_commit: $(Build.SourceVersion)
              EOF

              tar czf "$BUNDLE" \
                --transform "s,^,acme-hq-c1-${VERSION}/," \
                playbooks/ \
                roles/ \
                group_vars/ \
                collections/ \
                ansible.cfg \
                BUNDLE_MANIFEST.yml

              echo "##vso[task.setvariable variable=BundleFile]${BUNDLE}"
              ls -lh "$BUNDLE"
            displayName: Create bundle

          - script: |
              set -e
              VERSION="${{ parameters.version }}"
              BUNDLE="$(BundleFile)"
              TARGET_URL="$(ArtifactoryUrl)/artifactory/ansible-bundles-local/acme-hq-c1/${VERSION}/${BUNDLE}"

              curl -sf -H "Authorization: Bearer ${ARTIFACTORY_TOKEN}" \
                -T "$BUNDLE" \
                "$TARGET_URL"

              echo "Bundle published: $TARGET_URL"
            env:
              ARTIFACTORY_TOKEN: $(ArtifactoryToken)
            displayName: Publish bundle to Artifactory
