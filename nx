User root
Group nxlog
Panic Soft

# default values:
define INSTALLDIR /opt/nxlog
# PidFile   %INSTALLDIR%/var/run/nxlog/nxlog.pid
# CacheDir  %INSTALLDIR%/var/spool/nxlog
# ModuleDir %INSTALLDIR%/lib/nxlog/modules
# SpoolDir %INSTALLDIR%/var/spool/nxlog

define CERTDIR %INSTALLDIR%/var/lib/nxlog/cert
define CONFDIR %INSTALLDIR%/etc/nxlog.d

# Note that these two lines define constants only; the log file location
# is ultimately set by the `LogFile` directive (see below). The
# `MYLOGFILE` define is also used to rotate the log file automatically
# (see the `_fileop` block).
define LOGDIR %INSTALLDIR%/var/log/nxlog
define MYLOGFILE %LOGDIR%/nxlog.log

# If you are not using NXLog Manager, disable the `include` line
# and enable LogLevel and LogFile.
#include %CONFDIR%/*.conf
LogLevel    INFO
LogFile     %MYLOGFILE%

<Extension _syslog>
    Module  xm_syslog
</Extension>

<Extension json>
    Module xm_json
</Extension>

<Input usb_debug>
    Module        im_systemd
    ReadFromLast  TRUE
    SavePos       TRUE
    Exec if $Transport != "kernel" drop();
</Input>

<Extension pkg_kvp>
    Module          xm_kvp
    KVDelimiter     =
    KVPDelimiter    ' '
    ValueQuoteChar  "
</Extension>

<Extension audit_parser>
    Module      xm_kvp
    KVPDelimiter    ' '
    KVDelimiter     =
    EscapeChar      "\"
</Extension>

<Extension fw_parse>
    Module          xm_kvp
    KVPDelimiter    ' '
    KVDelimiter     '='
</Extension>

<Extension select_kvp>
    Module          xm_kvp
    KVPDelimiter    ';'
    KVDelimiter     '='
</Extension>

<Input user_select>
    Module          im_file
    File            "/var/log/secure"
    SavePos         TRUE
    ReadFromLast    TRUE
    <Exec>
        if $raw_event !~ /COMMAND=/ drop();

        if $raw_event =~ /sudo\[\d+\]:\s+(\S+)\s+:(.*)/
        {
            $sudo_user = $1;
            $kvp_part  = $2;
            select_kvp->parse_kvp($kvp_part);
        }
        $message = "User " + $sudo_user + " has elevated its privilages to " + $USER;
        $raw_event = $message;
    </Exec>
</Input>

<Input firewalld>
    Module  im_file
    File    "/var/log/messages"
    <Exec>
        if $raw_event !~ /(DROP|REJECT)/ drop();

        parse_syslog();

        if $Message =~ /^([A-Z_]*(DROP|REJECT)[A-Z_]*): (.+)/
        {
            $fw_prefix = $1;
            $Message   = $3;
        }

        # Parse the remaining key=value pairs
        fw_parse->parse_kvp($Message);
        $raw_event = $fw_prefix + $IN + $SRC + $DST + $PROTO;

        $fw_action = "DENY";
    </Exec>
</Input>

<Input packages>
    Module      im_file
    File        "/var/log/audit/audit.log"
    SavePos     TRUE
    ReadFromLast TRUE
    <Exec>
        if $raw_event =~ /^type=SOFTWARE_UPDATE/ {
            if $raw_event =~ /auid=(\d+)/ {
                $auid = $1;
            } else drop();
            if $raw_event =~ /msg='([^']+)'/ {
                $msg = $1;
            } else drop();
            pkg_kvp->parse_kvp($msg);
            if not defined($op) drop();
            if not defined($sw) drop();
            if $op == "install" {
                $message = "PACKAGE_INSTALL auid=" + $auid + " sw=" + $sw;
                $raw_event = $message;
            } else if $op == "remove" {
                $message = "PACKAGE_REMOVE auid=" + $auid + " sw=" + $sw;
                $raw_event = $message;
            } else {
                drop();
            }
        } else {
            drop();
        }
    </Exec>
</Input>

<Input services>
    Module      im_systemd
    ReadFromLast TRUE
    SavePos      TRUE
    <Exec>
        if $SourceName != "sudo" drop();
        if $Message !~ /systemctl\s+(start|stop|restart)/ drop();

        if $Message =~ /COMMAND=.*systemctl\s+(start|stop|restart)\s+(\S+)/ {
            $ServiceAction  = $1;
            $ServiceName    = $2;
            $UserId   = $AuditUID;
            $raw_event =  $EventTime + $ServiceAction + $ServiceName + $UserId;
        } else {
            drop();
        }
    </Exec> 
</Input>

<Input usb_kern>
    Module        im_systemd
    ReadFromLast  TRUE
    SavePos       TRUE
    Exec if $Transport != "kernel" drop();
    <Exec>
        $is_enum       = FALSE;
        $is_disconnect = FALSE;
        $is_storage    = FALSE;

        if not defined($DevName) or $DevName == "" drop();

        if $DevName =~ /(\d+-\d+)/
        {
            $usb_port = $1;
        }
        else drop();

        if $Message =~ /New\s+USB\s+device\s+found.*?idVendor\s*=\s*([0-9A-Fa-f]{4}).*?idProduct\s*=\s*([0-9A-Fa-f]{4})/i
        {
            $hwid      = $1 + ":" + $2;
            $is_enum   = TRUE;
            $Message   = 'USB DEVICE CONNECTED ' + $hwid;
            $raw_event = $Message;
        }

        if $Message =~ /USB\s+Mass\s+Storage\s+device\s+detected/i
        {
            $is_storage = TRUE;
            $Message    = 'USB_STORAGE_PENDING';
            $raw_event  = $Message;
        }

        if $Message =~ /USB\s+disconnect,\s+device\s+number\s+\d+/i
        {
            $is_disconnect = TRUE;
            $Message       = 'USB_DISCONNECT_PENDING';
            $raw_event     = $Message;
        }

        if not ($is_enum or $is_disconnect or $is_storage) drop();
    </Exec>
</Input>

<Input aide>
    Module  im_file
    File    "/var/log/aide/aide.log"

    <Exec>
        if $raw_event =~ /AIDE found differences between database and filesystem/
        {
            $EventType  = "AIDE_FIM_ALERT";
            $Severity   = "WARNING";
            $Message    = "AIDE detected filesystem changes on " + hostname();
            $EventTime  = now();
            $raw_event = $EventTime + $Severity + $Message;
        }
        else drop();
    </Exec>
</Input>

<Input fim>
    Module      im_fim
    Recursive   FALSE
    ScanInterval 300
    Digest      SHA1
    File        "/usr/bin/*"
    File        "/usr/sbin/*"
    File        "/usr/lib64/*"
    File        "/usr/lib/*"
    File        "/etc/*"
    File        "/etc/pam.d/*"
    File        "/etc/sudoers.d/*"
    File        "/etc/systemd/system/*"
    File        "/etc/cron.d/*"
    File        "/boot/*"
    File        "/etc/libvirt/*"
    File        "/etc/libvirt/qemu/*"
    File        "/etc/libvirt/storage/*"
    File        "/etc/libvirt/networks/*"
    File        "/var/lib/libvirt/network/*"
    File        "/var/lib/libvirt/qemu/nvram/*"
    Exclude     "/etc/resolv.conf"
    Exclude     "/var/lib/libvirt/images/*"
    Exclude     "/etc/adjtime"
    Exclude     "/etc/*.swp"
    Exclude     "/usr/lib64/*.cache"
    <Exec>
        $Hostname  = hostname_fqdn();
        $EventType = "FIM";
    </Exec>
</Input>

<Input time>
    Module      im_file
    File        "/var/log/audit/audit.log"
    SavePos     TRUE
    ReadFromLast TRUE
    <Exec>
        # Extract type from the start of the line
        if $raw_event =~ /^type=(\S+)/ $type = $1;

        # Extract auid via regex to avoid xm_kvp string/type issues
        #if $raw_event =~ /\auid=(\d+)/ $auid = $1;
        if $raw_event =~ /\bAUID="([^"]+)"/ $UserId = $1;

        # Extract key via regex, stripping the embedded quotes
        if $raw_event =~ /\bkey="([^"]+)"/ $key = $1;

        # Extract syscall name from the interpreted uppercase SYSCALL= field
        if $raw_event =~ /\bSYSCALL=(\S+)/ $syscall = $1;
        if $auid == "4294967295" drop();
        if $UserId == "unset" drop();
        if ($auid != "0") and ($auid < 1000) drop();

        # Only forward time-change syscall events
        if defined($key) and ($key == "time-change") {
            if $type != "SYSCALL" drop();
            if not ($syscall == "adjtimex" or $syscall == "settimeofday" or $syscall == "clock_settime" or $syscall == "clock_adjtime") drop();
            $raw_event = "TIME_CHANGE_DETECTED auid=" + $UserId + " syscall=" + $syscall;
        } else {
            drop();
        }
    </Exec>
</Input>

<Input user_audit>
    Module      im_file
    File        '/var/log/audit/audit.log'
    SavePos     TRUE
    ReadFromLast TRUE
    <Exec>
        if $raw_event !~ /^type=(USER_MGMT|ADD_USER|DEL_USER|USER_CHAUTHTOK)/ { drop(); }

        if $raw_event =~ /AUID="([^"]+)"/
            { $Actor = $1; }
        else
            { $Actor = "-"; }

        if $raw_event =~ /acct="([^"]+)"/
            { $TargetUser = $1; }
        else if $raw_event =~ / ID="([^"]+)"/
            { $TargetUser = $1; }
        else
            { $TargetUser = "-"; }

        if $raw_event =~ /grp="([^"]+)"/
            { $Group = $1; }
        else
            { $Group = "-"; }

        if $raw_event =~ /op=([a-z-]+)/
            { $Operation = $1; }
        else
            { $Operation = "-"; }

        if $raw_event =~ /^type=ADD_USER/
        {
            $raw_event = "Actor=" + $Actor + " created user TargetUser=" + $TargetUser;
        }
        else if $raw_event =~ /^type=DEL_USER/
        {
            $raw_event = "Actor=" + $Actor + " deleted user TargetUser=" + $TargetUser;
        }
        else if $raw_event =~ /^type=USER_CHAUTHTOK/
        {
            $raw_event = "Actor=" + $Actor + " changed password for TargetUser=" + $TargetUser;
        }
        else if $raw_event =~ /^type=USER_MGMT/
        {
            if $Operation == "add-user-to-group"
            {
                $raw_event = "Actor=" + $Actor + " added TargetUser=" + $TargetUser + " to Group=" + $Group;
            }
            else if $Operation == "delete-user-from-group"
            {
                $raw_event = "Actor=" + $Actor + " removed TargetUser=" + $TargetUser + " from Group=" + $Group;
            }
            else { drop(); }
        }
    </Exec>
</Input>

<Input audit_files>
    Module       im_file
    File         "/var/log/audit/audit.log"
    SavePos      TRUE
    ReadFromLast TRUE
    <Exec>
        # Drop non-SYSCALL/PATH record types immediately
        if $raw_event !~ /type=(SYSCALL|PATH)/ drop();

        # For SYSCALL records specifically, enforce the key filter
        # PATH records don't carry the key so we can't filter them here
        if $raw_event =~ /type=SYSCALL/ and $raw_event !~ /key="identity"/ drop();

        $is_syscall = FALSE;
        $is_path    = FALSE;

        if $raw_event =~ /type=SYSCALL/
        {
            if $raw_event =~ /SYSCALL=(openat|open)/
            {
                if $raw_event =~ /\ba2=([0-9a-fA-F]+)/
                {
                    if (integer("0x" + $1) % integer("0x400")) < integer("0x200") drop();
                }
            }

            if $raw_event =~ /msg=audit\([\d.]+:(\d+)\)/  $AuditSerial = $1;

            # Prefer the translated AUID="sysop" over numeric auid=1000
            if $raw_event =~ /AUID="([^"]+)"/             $AuditUser   = $1;
            if not defined($AuditUser) or $AuditUser == ""
            {
                if $raw_event =~ /\bauid=(\d+)/            $AuditUser   = $1;
            }

            if $raw_event =~ /comm="([^"]+)"/             $AuditComm   = $1;
            if $raw_event =~ /key="([^"]+)"/              $AuditKey    = $1;
            if $raw_event =~ /SYSCALL=(\w+)/              $SyscallName = $1;

            $is_syscall = TRUE;
        }
        else if $raw_event =~ /type=PATH/
        {
            if $raw_event =~ /nametype=PARENT/ drop();

            if $raw_event =~ /msg=audit\([\d.]+:(\d+)\)/  $AuditSerial = $1;
            if $raw_event =~ /name="([^"]+)"/             $FilePath    = $1;
            if $raw_event =~ /nametype=(\w+)/             $NameType    = $1;

            $is_path = TRUE;
        }

        else drop();
    </Exec>
</Input>

<Processor corr>
    Module pm_evcorr
    # Pair 1: connect -> storage = "USB MASS STORAGE DEVICE CONNECTED"
    <Pair>
        Context           $usb_port
        TriggerCondition  $is_enum == TRUE
        RequiredCondition $is_storage == TRUE
        Interval          30
        <Exec>
            $hwid       = get_prev_event_data("hwid");
            $event_type = "usb_storage_connect_enriched";
            $Message    = 'USB MASS STORAGE DEVICE CONNECTED ' + $hwid;
            $raw_event  = $Message;
        </Exec>
    </Pair>

    # Pair 2: connect -> disconnect = "USB DEVICE DISCONNECTED"
    <Pair>
        Context           $usb_port
        TriggerCondition  $is_enum == TRUE
        RequiredCondition $is_disconnect == TRUE
        Interval          3600
        <Exec>
            $hwid       = get_prev_event_data("hwid");
            $event_type = "usb_disconnect_enriched";
            $Message    = 'USB DEVICE DISCONNECTED ' + $hwid;
            $raw_event  = $Message;
        </Exec>
    </Pair>

    # Pair 3: storage -> disconnect = "USB MASS STORAGE DEVICE DISCONNECTED"
    <Pair>
        Context           $usb_port
        TriggerCondition  $is_storage == TRUE
        RequiredCondition $is_disconnect == TRUE
        Interval          3600
        <Exec>
            $event_type = "usb_storage_disconnect_enriched";
            $Message    = 'USB MASS STORAGE DEVICE DISCONNECTED';
            $raw_event  = $Message;
        </Exec>
    </Pair>
    <Pair>
        Context            $AuditSerial
        TriggerCondition   $is_syscall == TRUE
        RequiredCondition  $is_path == TRUE
        Interval           5
        <Exec>
            # Pull fields from the SYSCALL (trigger) event
            $AuditUser   = get_prev_event_data("AuditUser");
            $AuditComm   = get_prev_event_data("AuditComm");
            $AuditKey    = get_prev_event_data("AuditKey");
            $SyscallName = get_prev_event_data("SyscallName");

            # FilePath and NameType already available from the PATH (required) event
            $Message = "File " + $NameType + ": " + $FilePath + \
                       " | user=" + $AuditUser + \
                       " | comm=" + $AuditComm + \
                       " | syscall=" + $SyscallName + \
                       " | key=" + $AuditKey;
            $is_path    = FALSE;
            $is_syscall = FALSE;
            $raw_event = $Message;
        </Exec>
    </Pair>
</Processor>

<Output out_debug>
    Module om_file
    File   "/opt/nxlog/var/log/debug.json"
    <Exec>
        #to_json();
    </Exec>
</Output>

<Output out>
    Module om_file
    File   "/opt/nxlog/var/log/usb-disconnect-enriched.json"
    <Exec>
        to_json();
    </Exec>
</Output>

<Output out2>
    Module om_file
    File   "/opt/nxlog/var/log/package_remove.json"
    Exec   if $is_syscall == TRUE or $is_path == TRUE drop();
</Output>

#<Route r>
#    Path usb_kern => corr => out
#</Route>

<Route r2>
    Path usb_kern => out_debug
</Route>

<Route r3>
    Path audit_files, user_select, firewalld, aide, services, packages, user_audit, time, usb_kern => corr => out2
</Route>
