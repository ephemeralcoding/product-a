def qcow_local_path(build: dict[str, Any]) -> Path:
    """Local path where Packer produces the qcow."""
    return (
        PACKER_DIR / "output" / build["id"] / build["build_version"]
        / f"{build['id']}.qcow2"
    )


def qcow_remote_url(build: dict[str, Any], infra: dict[str, Any]) -> str:
    """Artifactory destination for the qcow."""
    return (
        f"{infra['artifactory']['url']}/artifactory/qcows-builds/"
        f"{build['location']}/{build['host']}/{build['build_version']}/"
        f"{build['host']}.qcow2"
    )


def upload_qcow(build: dict[str, Any], infra: dict[str, Any]) -> None:
    step(f"Upload: {build['id']}")
    local = qcow_local_path(build)
    if not local.exists():
        fail(
            f"Local qcow not found: {local.relative_to(REPO_ROOT)}\n"
            f"  Build it first: build-one --build-id {build['id']}"
        )

    url = qcow_remote_url(build, infra)
    info(f"Source: {local.relative_to(REPO_ROOT)}")
    info(f"  Size: {local.stat().st_size / (1024**3):.2f} GB")
    info(f"Target: {url}")

    token = require_env("ARTIFACTORY_TOKEN")
    args = [
        "curl", "-fsS",
        "-H", f"Authorization: Bearer {token}",
        "-T", str(local),
        url,
    ]
    printable = [a if "Bearer " not in a else "Authorization: Bearer ***" for a in args]
    cmd(printable)
    result = subprocess.run(args, check=False)
    if result.returncode != 0:
        fail(f"Upload failed (curl exit {result.returncode})")

    info("Upload complete.")




def cmd_upload_one(args) -> None:
    validate_environment()
    infra = load_yaml(INFRA)
    manifest = load_manifest()
    build = find_build(args.build_id, manifest)
    upload_qcow(build, infra)


def cmd_upload_all(args) -> None:
    validate_environment()
    infra = load_yaml(INFRA)
    manifest = load_manifest()
    step(f"Uploading all ({len(manifest)} builds)")
    for build in manifest:
        upload_qcow(build, infra)
    step("All uploads complete")


def cmd_build_and_upload_one(args) -> None:
    cmd_build_one(args)
    cmd_upload_one(args)


def cmd_build_and_upload_all(args) -> None:
    validate_environment()
    infra = load_yaml(INFRA)
    manifest = load_manifest()
    for build in manifest:
        ensure_iso(build["base_os"], infra)
        run_packer(build)
        upload_qcow(build, infra)



p_upload_one = sub.add_parser("upload-one", help="Upload one already-built qcow")
p_upload_one.add_argument("--build-id", required=True)
p_upload_one.set_defaults(func=cmd_upload_one)

p_upload_all = sub.add_parser("upload-all", help="Upload every already-built qcow")
p_upload_all.set_defaults(func=cmd_upload_all)

p_bau_one = sub.add_parser("build-and-upload-one", help="Build, then upload, one image")
p_bau_one.add_argument("--build-id", required=True)
p_bau_one.set_defaults(func=cmd_build_and_upload_one)

p_bau_all = sub.add_parser("build-and-upload-all", help="Build and upload every image")
p_bau_all.set_defaults(func=cmd_build_and_upload_all)


